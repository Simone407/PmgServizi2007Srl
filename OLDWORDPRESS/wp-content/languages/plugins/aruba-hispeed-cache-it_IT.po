#. translators: %2$s: the guide url.
#: src/AHSC_Check.php:254
msgid "<strong>The HiSpeed Cache service is not enabled.</strong> To activate it, go to your domain <a href=\"%1$s\" rel=\"nofollow\" target=\"_blank\">control panel</a> (verifying the status may take up to 15 minutes). For further details <a href=\"%2$s\" rel=\"nofollow\" target=\"_blank\">see our guide</a>."
msgstr "<strong>Il servizio HiSpeed Cache non è attivo.</strong> Accedi al <a href=\"%1$s\" rel=\"nofollow\" target=\"_blank\">pannello di controllo</a> del tuo dominio per attivarlo (il controllo dello stato di attivazione potrebbe richiedere fino a 15 minuti). Per maggiori dettagli <a href=\"%2$s\" rel=\"nofollow\" target=\"_blank\">consulta la nostra guida</a>."

